      </svg>
    </a>
    <nav class="hidden items-center gap-6 text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-paper-dim lg:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'transition hover:text-brass',
            currentPath === item.href ? 'text-brass' : 'text-paper-dim',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a
      href={ctaHref}
      class="rounded-full border border-brass/50 px-4 py-2 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-paper transition hover:border-brass hover:bg-brass hover:text-ink"
    >
      {ctaLabel}
    </a>
  </div>
  <div class="overflow-x-auto border-t border-white/[0.06] px-6 py-3 lg:hidden">
    <div class="mx-auto flex max-w-7xl gap-5 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-paper-dim">
      {navItems.map((item) => (
        <a href={item.href} class:list={[currentPath === item.href ? 'text-brass' : 'text-paper-dim']}>
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>
