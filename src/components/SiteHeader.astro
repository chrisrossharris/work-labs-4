---
import { contactProfile, navItems, operatingFormula } from '../data/site';

interface Props {
  ctaHref?: string;
  ctaLabel?: string;
  currentPath?: string;
}

const { ctaHref = '/contact', ctaLabel = 'Start a Conversation', currentPath = '' } = Astro.props;
---

<div class="site-topbar">
  <div class="site-topbar__inner">
    <span>{operatingFormula}</span>
    <span>{contactProfile.signoff}</span>
  </div>
</div>

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="brand-logo" aria-label="WORK LABS home">
      <span>WORK LABS</span><sup>CI²</sup>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a href={item.href} class:list={[currentPath === item.href ? 'is-active' : '']}>
          {item.label}
        </a>
      ))}
    </nav>

    <a class="site-cta" href={ctaHref}>{ctaLabel}</a>
  </div>

  <nav class="site-nav-mobile" aria-label="Mobile navigation">
    {navItems.map((item) => (
      <a href={item.href} class:list={[currentPath === item.href ? 'is-active' : '']}>
        {item.label}
      </a>
    ))}
  </nav>
</header>
