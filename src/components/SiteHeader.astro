---
import { contactProfile, navItems, operatingFormula } from '../data/site';

interface Props {
  ctaHref?: string;
  ctaLabel?: string;
  currentPath?: string;
}

const { ctaHref = '/contact', ctaLabel = 'Request a call', currentPath = '' } = Astro.props;
---

<div class="border-b border-white/[0.08] bg-black/30 px-6 py-3 lg:px-10">
  <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-paper-soft">
    <div class="text-brass">{operatingFormula}</div>
    <div class="text-paper-soft">{contactProfile.signoff}</div>
  </div>
</div>

<header class="sticky top-0 z-50 border-b border-white/[0.08] bg-ink/85 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-5 lg:px-10">
    <a href="/" class="text-paper no-underline transition hover:text-brass" aria-label="WORK LABS home">
      <svg
        class="h-auto w-[102px] lg:w-[114px]"
        viewBox="0 0 484 267"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-hidden="true"
        fill="currentColor"
