---
import type { PageData, Section } from '../data/site';
import SiteFooter from './SiteFooter.astro';
import SiteHeader from './SiteHeader.astro';

interface Props {
  page: PageData;
}

const { page } = Astro.props;
const isHome = page.path === '/';

const renderSectionBody = (section: Section) => ('body' in section ? section.body : undefined);
---

<div class="site-shell">
  <SiteHeader ctaHref={page.cta.href} ctaLabel={page.cta.label} currentPath={page.path} />

  <main>
    <section class="relative overflow-hidden border-b border-white/[0.08]">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brass/60 to-transparent"></div>
      <div class="absolute inset-y-0 right-0 hidden w-1/2 bg-[radial-gradient(circle_at_top,rgba(200,165,106,0.2),transparent_52%)] lg:block"></div>
      <div class="absolute left-[-10%] top-20 h-72 w-72 rounded-full bg-brass/10 blur-3xl"></div>
      <div class="mx-auto grid max-w-7xl gap-12 px-6 py-20 lg:grid-cols-[1.25fr_0.75fr] lg:px-10 lg:py-28">
        <div class="max-w-4xl">
          <div class="mb-6 text-xs font-semibold uppercase tracking-[0.28em] text-brass">
            {page.heroEyebrow}
          </div>
          <h1 class="text-balance max-w-5xl font-serif text-5xl leading-[0.95] text-paper sm:text-6xl lg:text-7xl">
            {page.heroTitle}
          </h1>
          <p class="mt-8 max-w-3xl text-lg leading-8 text-paper-dim sm:text-xl">
            {page.heroBody}
          </p>
          {page.heroNote && (
            <div class="mt-8 max-w-2xl border-l border-brass pl-5 text-sm uppercase tracking-[0.18em] text-paper-soft">
              {page.heroNote}
            </div>
          )}
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href={page.cta.href}
              class="rounded-full bg-brass px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-ink transition hover:bg-sand"
            >
              {page.cta.label}
            </a>
            {!isHome && (
              <a
                href="/"
                class="rounded-full border border-white/12 px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-paper transition hover:border-brass hover:text-brass"
              >
                Back to home
              </a>
            )}
          </div>
        </div>

        <div class="grid gap-5 self-end">
          <div class="glass-panel rounded-[2rem] p-6 lg:p-8">
            <div class="text-xs font-semibold uppercase tracking-[0.24em] text-brass">Operating philosophy</div>
            <div class="mt-5 font-serif text-3xl leading-tight text-paper">
              (AI²) + (HI²) = (CI²)
            </div>
            <p class="mt-4 text-base leading-7 text-paper-dim">
              Collaborative Intelligence is the thinking framework running through branding,
              strategy, identity, packaging, consulting, and the future structure of WORK LABS.
            </p>
          </div>
        </div>
      </div>
    </section>

    {page.sections.map((section) => (
      <section class="border-b border-white/[0.08]">
        <div class="mx-auto max-w-7xl px-6 py-20 lg:px-10 lg:py-24">
          <div class="max-w-3xl">
            {section.eyebrow && (
              <div class="mb-4 text-xs font-semibold uppercase tracking-[0.26em] text-brass">
                {section.eyebrow}
              </div>
            )}
            <h2 class="text-balance max-w-4xl font-serif text-4xl leading-tight text-paper sm:text-5xl">
              {section.title}
            </h2>
            {renderSectionBody(section) && (
              <p class="mt-5 max-w-3xl text-lg leading-8 text-paper-dim">{renderSectionBody(section)}</p>
            )}
          </div>

          {section.type === 'intro' && (
            <div class="mt-10 max-w-4xl rounded-[2rem] border border-white/[0.08] bg-white/[0.03] p-8 text-lg leading-8 text-paper-dim">
              {section.body}
            </div>
          )}

          {section.type === 'cards' && (
            <div class="section-grid mt-12 md:grid-cols-2 xl:grid-cols-3">
              {section.items.map((item) => (
                <article class="glass-panel rounded-[1.75rem] p-7">
                  <h3 class="text-2xl font-serif text-paper">{item.title}</h3>
                  <p class="mt-4 text-base leading-7 text-paper-dim">{item.body}</p>
                  {item.href && item.cta && (
                    <a
                      href={item.href}
                      class="mt-6 inline-flex text-sm font-semibold uppercase tracking-[0.18em] text-brass no-underline"
                    >
                      {item.cta}
                    </a>
                  )}
                </article>
              ))}
            </div>
          )}

          {section.type === 'timeline' && (
            <div class="mt-12 space-y-4">
              {section.items.map((item) => (
                <article class="grid gap-4 rounded-[1.5rem] border border-white/[0.08] bg-white/[0.03] p-6 md:grid-cols-[140px_1fr] md:items-start">
                  <div class="text-xl font-semibold tracking-[0.2em] text-brass">{item.year}</div>
                  <div>
                    <h3 class="text-2xl font-serif text-paper">{item.title}</h3>
                    <p class="mt-3 max-w-4xl text-base leading-7 text-paper-dim">{item.body}</p>
                  </div>
                </article>
              ))}
            </div>
          )}

          {section.type === 'bullets' && (
            <div class="mt-10 grid gap-4 md:grid-cols-2">
              {section.items.map((item) => (
                <div class="rounded-[1.5rem] border border-white/[0.08] bg-white/[0.03] p-6 text-base leading-7 text-paper-dim">
                  {item}
                </div>
              ))}
            </div>
          )}

          {section.type === 'metrics' && (
            <div class="mt-10 grid gap-4 md:grid-cols-3">
              {section.metrics.map((metric) => (
                <div class="rounded-[1.75rem] border border-white/[0.08] bg-brass/[0.08] p-7">
                  <div class="font-serif text-4xl text-paper">{metric.value}</div>
                  <div class="mt-3 text-sm uppercase tracking-[0.18em] text-paper-dim">{metric.label}</div>
                </div>
              ))}
            </div>
          )}
        </div>
      </section>
    ))}
  </main>

  <SiteFooter />
</div>
