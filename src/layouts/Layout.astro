---
import '../styles/global.css';

interface Props {
	description?: string;
	title?: string;
}

const {
	description = 'WORK LABS is a brand strategy and creative studio building enduring systems across Collaborative Intelligence, Brand Foundry, Consulting, and Portfolio.',
	title = 'WORK LABS',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="bg-ink text-paper">
		<slot />
	</body>
</html>
