---
import BrandPlatformGrid from '../components/BrandPlatformGrid.astro';
import PageFrame from '../components/PageFrame.astro';
import { foundryPage } from '../data/site';
---

<PageFrame title={foundryPage.title} description={foundryPage.metaDescription} currentPath="/brand-foundry" ctaHref="/contact" ctaLabel="Begin Inquiry">
  <section class="hero">
    <div class="container">
      <div class="eyebrow" data-reveal>The WORK Brand Foundry™</div>
      <h1 class="page-title" data-reveal>Brands built inside<br /><span class="italic muted">Collaborative Intelligence.</span></h1>
      <p class="hero__sub" data-reveal>A curated inventory of investment-grade brand platforms, strategically conceived, creatively developed, and built inside a proprietary intelligence framework.</p>
      <div class="hero__actions" data-reveal>
        <a class="btn btn--primary" href="#inventory">View the Platforms</a>
        <a class="btn" href="/contact">Request Access</a>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container split">
      <div>
        <div class="eyebrow" data-reveal>Why These Brands Are Different</div>
        <h2 class="section-title" data-reveal>Most brand concepts are decks.<br /><span class="italic muted">These are assets.</span></h2>
      </div>
      <div>
        <p class="lede" data-reveal>The market is full of ideas looking for homes: names, logos, pitch decks, and hopeful language. WORK LABS Foundry brands are different.</p>
        <p class="lede" data-reveal>Each has been positioned, named, designed, and pressure-tested before it reaches a client's hands. What an acquirer receives is a platform built for operators who understand the difference between a logo and a legacy.</p>
      </div>
    </div>
  </section>

  <section class="section section--dark" id="inventory">
    <div class="container">
      <div class="split split--end">
        <div>
          <div class="eyebrow" data-reveal>Current Inventory · Five Brand Platforms</div>
          <h2 class="section-title" data-reveal>Five platforms. Five categories.<br /><span class="italic muted">One operating system.</span></h2>
        </div>
        <p class="lede" data-reveal>Click any platform for a launch-readiness dossier. The public preview is intentionally concise; deeper briefs are reserved for qualified conversations.</p>
      </div>
      <BrandPlatformGrid />
    </div>
  </section>

  <section class="section section--light">
    <div class="container split">
      <div>
        <div class="eyebrow" data-reveal>The Methodology</div>
        <h2 class="section-title" data-reveal>Built inside a system,<br /><span class="italic muted">not assembled from a brief.</span></h2>
      </div>
      <div>
        <p class="lede" data-reveal>Every Foundry brand begins inside WORK Brand Intelligence™, a system for evaluating, positioning, and structuring brands before a single creative decision is made.</p>
        <p class="lede" data-reveal>Artificial intelligence accelerates possibility. Human intelligence directs meaning. Collaborative Intelligence turns both into a stronger platform.</p>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="eyebrow" data-reveal>How Access Works</div>
      <h2 class="section-title" data-reveal>Selective by design.</h2>
      <div class="cards-grid" style="margin-top:70px;">
        {[
          ['01', 'Public preview', 'The five visible platforms introduce the Foundry model and establish the quality threshold.'],
          ['02', 'Qualified inquiry', 'Briefs are shared when there is real operator fit, category interest, and timing.'],
          ['03', 'Commissioned development', 'For the right opportunity, WORK LABS can build a new platform through the same CI² process.'],
        ].map(([number, title, body]) => (
          <article class="card" data-reveal>
            <div class="card__number">{number}</div>
            <h3 class="card-title">{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <div class="eyebrow" data-reveal>The Process</div>
      <h2 class="section-title" data-reveal>From intelligence to platform.</h2>
      <div class="cards-grid" style="margin-top:70px;">
        {[
          ['01', 'Frame', 'Category opportunity, audience truth, naming territory, commercial shape.'],
          ['02', 'Build', 'Identity, voice, launch narrative, application paths, partnership logic.'],
          ['03', 'Handoff', 'A concise operator brief with what exists, what it can become, and how to move.'],
        ].map(([number, title, body]) => (
          <article class="card" data-reveal>
            <div class="card__number">{number}</div>
            <h3 class="card-title">{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark" style="text-align:center;">
    <div class="container">
      <div class="eyebrow" data-reveal>Begin Carefully</div>
      <h2 class="section-title" data-reveal style="margin-inline:auto;">The strongest Foundry conversations start with category, timing, and intent.</h2>
      <div class="hero__actions" data-reveal style="justify-content:center;">
        <a class="btn btn--primary" href="/contact">Begin a Foundry Inquiry</a>
      </div>
    </div>
  </section>
</PageFrame>
