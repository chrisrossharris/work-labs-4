---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import {
  contactProfile,
  foundryHeroBrands,
  foundryPage,
} from '../data/site';
import Layout from '../layouts/Layout.astro';

const [introSection, whySection, engageSection, accessSection, buyersSection, inquirySection] =
  foundryPage.sections;
---

<Layout title={foundryPage.title} description={foundryPage.metaDescription}>
  <div class="site-shell">
    <SiteHeader currentPath="/brand-foundry" ctaHref="/contact" ctaLabel={foundryPage.cta.label} />

    <main>
      <section class="relative overflow-hidden border-b border-white/[0.08]">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(200,165,106,0.16),transparent_30%),radial-gradient(circle_at_80%_18%,rgba(255,255,255,0.05),transparent_24%)]"></div>
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brass/60 to-transparent"></div>
        <div class="mx-auto grid max-w-7xl gap-10 px-6 py-18 lg:grid-cols-[0.95fr_1.05fr] lg:items-end lg:px-10 lg:py-26">
          <div class="relative z-10">
            <div class="text-xs font-semibold uppercase tracking-[0.28em] text-brass">
              {foundryPage.heroEyebrow}
            </div>
            <h1 class="mt-6 max-w-[12ch] font-serif text-[3.2rem] leading-[0.96] text-paper sm:text-[3.8rem] lg:text-[4.35rem]">
              {foundryPage.heroTitle}
            </h1>
            <p class="mt-8 max-w-3xl text-lg leading-8 text-paper-dim sm:text-xl">
              {foundryPage.heroBody}
            </p>
            {foundryPage.heroNote && (
              <div class="mt-8 max-w-2xl border-l border-brass pl-5 text-sm uppercase tracking-[0.18em] text-paper-soft">
                {foundryPage.heroNote}
              </div>
            )}
            <div class="mt-10 flex flex-wrap gap-4">
              <a
                href={foundryPage.cta.href}
                class="rounded-full bg-brass px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-ink transition hover:bg-sand"
              >
                {foundryPage.cta.label}
              </a>
              <a
                href="#public-inventory"
                class="rounded-full border border-white/[0.12] px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-paper transition hover:border-brass hover:text-brass"
              >
                View public inventory
              </a>
            </div>
          </div>

          <div class="relative z-10 overflow-hidden rounded-[2rem] border border-white/[0.08] bg-white/[0.03] p-4 lg:p-5">
            <img
              src="/images/brand-foundry-brands-ready.png"
              alt="The Big Thinker's Brainstorming & Idea Co."
              class="h-auto w-full rounded-[1.4rem] object-cover"
            />
            <div class="grid gap-4 px-3 py-5 lg:grid-cols-[1fr_1fr]">
              <div>
                <div class="text-xs font-semibold uppercase tracking-[0.22em] text-brass">Public preview</div>
                <p class="mt-3 text-sm leading-7 text-paper-dim">
                  A small selection of hero brands introduces the Foundry and opens the door to
                  deeper category conversations.
                </p>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-[0.22em] text-brass">Private depth</div>
                <p class="mt-3 text-sm leading-7 text-paper-dim">
                  Broader inventory stays available by request for qualified buyers, operators, and
                  commissioned opportunities.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="border-b border-white/[0.08]">
        <div class="mx-auto max-w-5xl px-6 py-20 lg:px-10 lg:py-24">
          <div class="text-xs font-semibold uppercase tracking-[0.26em] text-brass">{introSection.eyebrow}</div>
          <h2 class="mt-4 font-serif text-4xl leading-tight text-paper sm:text-5xl">{introSection.title}</h2>
          <p class="mt-8 max-w-4xl text-lg leading-8 text-paper-dim">{introSection.body}</p>
        </div>
      </section>

      <section id="public-inventory" class="bg-sand text-ink">
        <div class="mx-auto max-w-7xl px-6 py-20 lg:px-10 lg:py-24">
          <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.26em] text-brass-soft">Public inventory</div>
              <h2 class="mt-4 font-serif text-4xl leading-tight sm:text-5xl">
                Five hero brands introduce the Foundry.
              </h2>
            </div>
            <p class="max-w-3xl text-lg leading-8 text-stone-700">
              Each concept is a signal of how WORK LABS thinks: category-aware, strategically
              framed, and designed with enough conceptual strength to support ownership, activation,
              and growth.
            </p>
          </div>

          <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
            {foundryHeroBrands.map((brand) => (
              <article class="overflow-hidden rounded-[1.7rem] border border-black/[0.08] bg-white/[0.65]">
                <div class="relative aspect-[4/4.6] overflow-hidden border-b border-black/[0.08] bg-[linear-gradient(180deg,#f4f1ea_0%,#ece7de_100%)]">
                  <img
                    src={brand.image}
                    alt={brand.title}
                    class="mx-auto h-full w-full object-contain p-6"
                    loading="lazy"
                  />
                  <div class="absolute left-4 right-4 top-4 flex items-center justify-between text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-stone-400">
                    <span>CI²</span>
                    <span>{brand.status}</span>
                  </div>
                </div>
                <div class="grid gap-3 p-5">
                  <div class="font-serif text-2xl leading-tight text-stone-900">{brand.title}</div>
                  <div class="text-xs uppercase tracking-[0.18em] text-stone-500">{brand.category}</div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="border-b border-white/[0.08]">
        <div class="mx-auto max-w-7xl px-6 py-20 lg:px-10 lg:py-24">
          <div class="max-w-4xl">
            <div class="text-xs font-semibold uppercase tracking-[0.26em] text-brass">{whySection.eyebrow}</div>
            <h2 class="mt-4 font-serif text-4xl leading-tight text-paper sm:text-5xl">{whySection.title}</h2>
          </div>
          <div class="mt-12 grid gap-5 lg:grid-cols-3">
            {'items' in whySection &&
              whySection.items.map((item) => (
                <article class="rounded-[1.75rem] border border-white/[0.08] bg-white/[0.03] p-7">
                  <h3 class="font-serif text-2xl text-paper">{item.title}</h3>
                  <p class="mt-4 text-base leading-7 text-paper-dim">{item.body}</p>
                </article>
              ))}
          </div>
        </div>
      </section>

      <section class="border-b border-white/[0.08] bg-white/[0.02]">
        <div class="mx-auto max-w-7xl px-6 py-20 lg:px-10 lg:py-24">
          <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.26em] text-brass">{engageSection.eyebrow}</div>
              <h2 class="mt-4 font-serif text-4xl leading-tight text-paper sm:text-5xl">{engageSection.title}</h2>
            </div>
            <p class="max-w-3xl text-lg leading-8 text-paper-dim">
              There is no single entry point because buyers come to the Foundry with different
              goals. Some want visibility into the current public concepts. Some want access to a
              broader category-specific inventory. Some want a new platform developed from the
              ground up.
            </p>
          </div>
          <div class="mt-12 grid gap-5 lg:grid-cols-3">
            {'items' in engageSection &&
              engageSection.items.map((item) => (
                <article class="rounded-[1.75rem] border border-white/[0.08] bg-black/20 p-7">
                  <h3 class="font-serif text-2xl text-paper">{item.title}</h3>
                  <p class="mt-4 text-base leading-7 text-paper-dim">{item.body}</p>
                </article>
              ))}
          </div>
        </div>
      </section>

      <section class="bg-sand text-ink">
        <div class="mx-auto max-w-7xl px-6 py-20 lg:px-10 lg:py-24">
          <div class="grid gap-6 lg:grid-cols-3">
            <div class="lg:col-span-1">
              <div class="text-xs font-semibold uppercase tracking-[0.26em] text-brass-soft">{accessSection.eyebrow}</div>
              <h2 class="mt-4 font-serif text-4xl leading-tight sm:text-5xl">{accessSection.title}</h2>
            </div>
            <div class="grid gap-4 lg:col-span-2 md:grid-cols-3">
              {'items' in accessSection &&
                accessSection.items.map((item) => (
                  <div class="rounded-[1.5rem] border border-black/[0.08] bg-white/[0.6] p-6 text-base leading-7 text-stone-700">
                    {item}
                  </div>
                ))}
            </div>
          </div>
        </div>
      </section>

      <section class="border-b border-white/[0.08]">
        <div class="mx-auto max-w-7xl px-6 py-20 lg:px-10 lg:py-24">
          <div class="max-w-4xl">
            <div class="text-xs font-semibold uppercase tracking-[0.26em] text-brass">{buyersSection.eyebrow}</div>
            <h2 class="mt-4 font-serif text-4xl leading-tight text-paper sm:text-5xl">{buyersSection.title}</h2>
          </div>
          <div class="mt-12 grid gap-5 lg:grid-cols-3">
            {'items' in buyersSection &&
              buyersSection.items.map((item) => (
                <article class="rounded-[1.75rem] border border-white/[0.08] bg-white/[0.03] p-7">
                  <h3 class="font-serif text-2xl text-paper">{item.title}</h3>
                  <p class="mt-4 text-base leading-7 text-paper-dim">{item.body}</p>
                </article>
              ))}
          </div>
        </div>
      </section>

      <section class="relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(200,165,106,0.18),transparent_34%)]"></div>
        <div class="mx-auto max-w-7xl px-6 py-24 lg:px-10 lg:py-28">
          <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.26em] text-brass">{inquirySection.eyebrow}</div>
              <h2 class="mt-4 font-serif text-4xl leading-tight text-paper sm:text-5xl">{inquirySection.title}</h2>
              <div class="mt-8 rounded-[1.7rem] border border-white/[0.08] bg-white/[0.03] p-7">
                <div class="text-xs font-semibold uppercase tracking-[0.22em] text-brass">Direct inquiry</div>
                <div class="mt-4 font-serif text-2xl text-paper">{contactProfile.name}</div>
                <div class="mt-1 text-sm uppercase tracking-[0.18em] text-paper-soft">{contactProfile.role}</div>
                <a href={contactProfile.mailto} class="mt-6 block text-base text-paper-dim transition hover:text-brass">{contactProfile.email}</a>
                <a href={contactProfile.phoneHref} class="mt-2 block text-base text-paper-dim transition hover:text-brass">{contactProfile.phone}</a>
              </div>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
              {'items' in inquirySection &&
                inquirySection.items.map((item) => (
                  <div class="rounded-[1.5rem] border border-white/[0.08] bg-black/20 p-6 text-base leading-7 text-paper-dim">
                    {item}
                  </div>
                ))}
            </div>
          </div>
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
