---
import PageFrame from '../components/PageFrame.astro';
import { legacyPortfolioCategories, legacyPortfolioCategoryWork, legacyPortfolioProjects } from '../data/legacyPortfolio';
import { portfolioPage, portfolioStudies } from '../data/site';

const legacyCategoryImages = new Set(legacyPortfolioCategoryWork.flatMap((item) => item.imageSet));

const featuredItems = portfolioStudies.map((study) => ({
  brand: study.brand,
  categoryLabel: study.medium,
  categories: ['Featured', ...study.categories],
  image: study.image,
  imageSet: [study.image],
  isLogo: false,
  projectNumber: '',
  source: 'Featured Work',
  sourceHref: '',
  summary: study.summary,
  title: study.title,
}));

const legacyGalleryItems = legacyPortfolioCategoryWork.map((item) => ({
  ...item,
  isLogo: item.categories.includes('Logo Design'),
}));

const legacyBrandItems = legacyPortfolioProjects
  .filter((item) => !item.image || !legacyCategoryImages.has(item.image))
  .map((item) => ({
    ...item,
    isLogo: item.categories.includes('Logo Design'),
  }));

const portfolioItems = [...featuredItems, ...legacyGalleryItems, ...legacyBrandItems].filter((item, index, items) => {
  const key = item.image ? `image:${item.image}` : `brand:${item.brand}:${item.categoryLabel}`;
  return items.findIndex((candidate) => {
    const candidateKey = candidate.image ? `image:${candidate.image}` : `brand:${candidate.brand}:${candidate.categoryLabel}`;
    return candidateKey === key;
  }) === index;
});

const preferredCategoryOrder = [
  'All Work',
  'Featured',
  ...legacyPortfolioCategories.map((category) => category.title),
  'Campaign',
  'Brand Systems',
  'Archive',
];

const availableCategories = Array.from(new Set(portfolioItems.flatMap((item) => item.categories)));
const categoryFilters = [
  ...preferredCategoryOrder.filter((category) => category === 'All Work' || availableCategories.includes(category)),
  ...availableCategories
    .filter((category) => !preferredCategoryOrder.includes(category))
    .sort((a, b) => a.localeCompare(b)),
];

const brandFilters = [
  'All Brands',
  ...Array.from(new Set(portfolioItems.map((item) => item.brand))).sort((a, b) => a.localeCompare(b)),
];

const archiveMetrics = [
  [`${portfolioItems.length}`, 'portfolio cards'],
  [`${legacyPortfolioProjects.length}`, 'brand/project records imported'],
  [`${legacyPortfolioCategories.length}`, 'legacy category views represented'],
];

const viewingPractice = [
  {
    body: 'Scan first. The strongest work earns attention before the caption has to explain it.',
    number: '01',
    title: 'Start with impact',
  },
  {
    body: 'Filter by category when you want proof of a capability: identity, packaging, digital, campaign, or collateral.',
    number: '02',
    title: 'Then judge the craft',
  },
  {
    body: 'Filter by brand when you want to see whether the idea survives across different forms and touchpoints.',
    number: '03',
    title: 'Look for system strength',
  },
  {
    body: 'The final question is not whether it is attractive. It is whether it makes the brand easier to recognize, remember, and believe.',
    number: '04',
    title: 'End with market effect',
  },
];

---

<PageFrame title="Work | WORK LABS" description={portfolioPage.metaDescription} currentPath="/work" ctaHref="/contact" ctaLabel="Discuss a Project">
  <section class="hero">
    <div class="container">
      <div class="eyebrow" data-reveal>The Portfolio</div>
      <h1 class="page-title" data-reveal>The work has always been<br /><span class="italic muted">the argument.</span></h1>
      <p class="hero__sub" data-reveal>The full archive from the previous portfolio has been brought into this page: category galleries, brand/project records, logo work, and selected featured pieces, all organized for faster review.</p>
      <div class="archive-metrics" data-reveal>
        {archiveMetrics.map(([value, label]) => (
          <div>
            <strong>{value}</strong>
            <span>{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split split--end">
        <div>
          <div class="eyebrow" data-reveal>How to View the Work</div>
          <h2 class="section-title" data-reveal>Do not review it as decoration.<br /><span class="italic muted">Review it as evidence.</span></h2>
        </div>
        <p class="lede" data-reveal>The best read of a portfolio is not a mood-board pass. It is a sequence: impact, craft, system strength, and market effect.</p>
      </div>
      <div class="work-guide">
        {viewingPractice.map((item) => (
          <article class="work-guide-card" data-reveal>
            <strong>{item.number}</strong>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--light portfolio-browser" data-portfolio-browser>
    <div class="container">
      <div class="split split--end">
        <div>
          <div class="eyebrow" data-reveal>Portfolio Browser</div>
          <h2 class="section-title" data-reveal>View the work by category<br /><span class="italic muted">or by brand.</span></h2>
        </div>
        <p class="lede" data-reveal>A single archive across the old category views and brand index. Use categories to evaluate capability, and brands to evaluate consistency of thought. Cards with multiple images open into a focused viewer.</p>
      </div>

      <div class="portfolio-controls" data-reveal>
        <div class="portfolio-filter">
          <span class="filter-label">Category</span>
          <div class="filter-pills" aria-label="View work by category">
            {categoryFilters.map((category) => (
              <button
                class={category === 'All Work' ? 'filter-pill is-active' : 'filter-pill'}
                type="button"
                data-filter-category={category}
                aria-pressed={category === 'All Work' ? 'true' : 'false'}
              >
                {category}
              </button>
            ))}
          </div>
        </div>
        <label class="portfolio-filter portfolio-filter--brand">
          <span class="filter-label">Brand</span>
          <select data-brand-filter aria-label="View work by brand">
            {brandFilters.map((brand) => <option value={brand}>{brand}</option>)}
          </select>
        </label>
      </div>

      <div class="portfolio-status" data-portfolio-status data-reveal>{portfolioItems.length} pieces shown</div>

      <div class="portfolio-grid portfolio-grid--browser" data-portfolio-grid>
        {portfolioItems.map((item) => (
          <article
            class={`work-tile work-tile--portfolio ${item.isLogo ? 'work-tile--logo' : ''}`}
            data-portfolio-item
            data-brand={item.brand}
            data-categories={item.categories.join('|')}
            data-images={JSON.stringify(item.imageSet)}
            data-meta={item.categoryLabel}
            data-summary={item.summary}
            data-title={item.brand}
            data-reveal
          >
            <button class="work-tile__image work-tile__image-button" type="button" data-portfolio-open aria-label={`View ${item.brand}`}>
              {item.image ? (
                <img src={item.image} alt={`${item.brand} ${item.categoryLabel}`} loading="lazy" />
              ) : (
                <span class="work-tile__placeholder">{item.brand}</span>
              )}
              {item.imageSet.length > 1 && <span class="work-tile__count">{item.imageSet.length} images</span>}
            </button>
            <div class="work-tile__content">
              <div class="work-tile__meta">
                <strong>{item.brand}</strong>
                <span>{item.categoryLabel}</span>
              </div>
              {item.projectNumber && <div class="work-tile__project">{item.projectNumber}</div>}
              <p class="work-tile__summary">{item.summary}</p>
              <div class="work-tile__tags" aria-label={`${item.brand} categories`}>
                {item.categories.map((category) => <span>{category}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>
      <p class="portfolio-empty" data-portfolio-empty hidden>No work matches that combination. Reset the brand or category to widen the view.</p>
    </div>
  </section>

  <section class="section section--dark" style="text-align:center;">
    <div class="container">
      <h2 class="section-title" data-reveal style="margin-inline:auto;">Recognized across major industry award shows and built across decades of category work.</h2>
      <p class="lede" data-reveal style="margin:28px auto 0;">Cannes Lions, The Clio Awards, The One Show, Communication Arts, Art Directors Club, Richmond Ad Club Hall of Fame, and Virginia Communications Hall of Fame.</p>
      <div class="hero__actions" data-reveal style="justify-content:center;">
        <a class="btn btn--primary" href="/contact">Start a Conversation</a>
      </div>
    </div>
  </section>
</PageFrame>

<div class="portfolio-modal" data-portfolio-modal aria-hidden="true" role="dialog" aria-modal="true" aria-label="Portfolio image viewer">
  <button class="portfolio-modal__backdrop" type="button" data-portfolio-modal-close aria-label="Close portfolio viewer"></button>
  <div class="portfolio-modal__panel">
    <button class="portfolio-modal__close" type="button" data-portfolio-modal-close aria-label="Close">x</button>
    <button class="portfolio-modal__nav portfolio-modal__nav--prev" type="button" data-portfolio-modal-prev aria-label="Previous image">&lt;</button>
    <figure class="portfolio-modal__figure">
      <img src="" alt="" data-portfolio-modal-image />
      <figcaption>
        <strong data-portfolio-modal-title></strong>
        <span data-portfolio-modal-meta></span>
        <p data-portfolio-modal-summary></p>
      </figcaption>
    </figure>
    <button class="portfolio-modal__nav portfolio-modal__nav--next" type="button" data-portfolio-modal-next aria-label="Next image">&gt;</button>
  </div>
</div>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-portfolio-browser]');
    if (!root) return;

    const categoryButtons = Array.from(root.querySelectorAll('[data-filter-category]'));
    const brandFilter = root.querySelector('[data-brand-filter]');
    const items = Array.from(root.querySelectorAll('[data-portfolio-item]'));
    const status = root.querySelector('[data-portfolio-status]');
    const empty = root.querySelector('[data-portfolio-empty]');
    const modal = document.querySelector('[data-portfolio-modal]');
    const modalImage = modal?.querySelector('[data-portfolio-modal-image]');
    const modalTitle = modal?.querySelector('[data-portfolio-modal-title]');
    const modalMeta = modal?.querySelector('[data-portfolio-modal-meta]');
    const modalSummary = modal?.querySelector('[data-portfolio-modal-summary]');
    const modalPrev = modal?.querySelector('[data-portfolio-modal-prev]');
    const modalNext = modal?.querySelector('[data-portfolio-modal-next]');
    const modalClose = Array.from(document.querySelectorAll('[data-portfolio-modal-close]'));
    let activeCategory = 'All Work';
    let activeImages = [];
    let activeImageIndex = 0;
    let activeModalCopy = { meta: '', summary: '', title: '' };

    const updatePortfolio = () => {
      const activeBrand = brandFilter?.value || 'All Brands';
      let visibleCount = 0;

      items.forEach((item) => {
        const categories = (item.dataset.categories || '').split('|');
        const matchesCategory = activeCategory === 'All Work' || categories.includes(activeCategory);
        const matchesBrand = activeBrand === 'All Brands' || item.dataset.brand === activeBrand;
        const isVisible = matchesCategory && matchesBrand;

        item.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      });

      categoryButtons.forEach((button) => {
        const isActive = button.dataset.filterCategory === activeCategory;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-pressed', String(isActive));
      });

      if (status) {
        status.textContent = `${visibleCount} ${visibleCount === 1 ? 'piece' : 'pieces'} shown`;
      }

      if (empty) {
        empty.hidden = visibleCount !== 0;
      }
    };

    categoryButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeCategory = button.dataset.filterCategory || 'All Work';
        updatePortfolio();
      });
    });

    brandFilter?.addEventListener('change', updatePortfolio);
    updatePortfolio();

    const renderModalImage = () => {
      if (!modal || !modalImage || activeImages.length === 0) return;

      modalImage.src = activeImages[activeImageIndex];
      modalImage.alt = `${activeModalCopy.title} portfolio image ${activeImageIndex + 1}`;

      if (modalTitle) modalTitle.textContent = activeModalCopy.title;
      if (modalMeta) modalMeta.textContent = `${activeModalCopy.meta} / ${activeImageIndex + 1} of ${activeImages.length}`;
      if (modalSummary) modalSummary.textContent = activeModalCopy.summary;

      const hasMultiple = activeImages.length > 1;
      if (modalPrev) modalPrev.hidden = !hasMultiple;
      if (modalNext) modalNext.hidden = !hasMultiple;
    };

    const openModal = (item) => {
      if (!modal) return;

      try {
        activeImages = JSON.parse(item.dataset.images || '[]').filter(Boolean);
      } catch {
        activeImages = [];
      }

      if (activeImages.length === 0) return;

      activeImageIndex = 0;
      activeModalCopy = {
        meta: item.dataset.meta || '',
        summary: item.dataset.summary || '',
        title: item.dataset.title || '',
      };

      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('portfolio-modal-open');
      renderModalImage();
    };

    const closeModal = () => {
      if (!modal) return;
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('portfolio-modal-open');
    };

    root.querySelectorAll('[data-portfolio-open]').forEach((button) => {
      button.addEventListener('click', () => {
        const item = button.closest('[data-portfolio-item]');
        if (item) openModal(item);
      });
    });

    modalPrev?.addEventListener('click', () => {
      activeImageIndex = (activeImageIndex - 1 + activeImages.length) % activeImages.length;
      renderModalImage();
    });

    modalNext?.addEventListener('click', () => {
      activeImageIndex = (activeImageIndex + 1) % activeImages.length;
      renderModalImage();
    });

    modalClose.forEach((button) => button.addEventListener('click', closeModal));

    document.addEventListener('keydown', (event) => {
      if (!modal?.classList.contains('is-open')) return;
      if (event.key === 'Escape') closeModal();
      if (event.key === 'ArrowLeft' && activeImages.length > 1) {
        activeImageIndex = (activeImageIndex - 1 + activeImages.length) % activeImages.length;
        renderModalImage();
      }
      if (event.key === 'ArrowRight' && activeImages.length > 1) {
        activeImageIndex = (activeImageIndex + 1) % activeImages.length;
        renderModalImage();
      }
    });
  })();
</script>
