---
import PageFrame from '../components/PageFrame.astro';
import { contactPage, contactPaths, contactProfile } from '../data/site';
---

<PageFrame title={contactPage.title} description={contactPage.metaDescription} currentPath="/contact" ctaHref={contactProfile.mailto} ctaLabel="Email WORK LABS">
  <section class="hero">
    <div class="container">
      <div class="eyebrow" data-reveal>Start a Conversation</div>
      <h1 class="page-title" data-reveal>Time is everyone's<br /><span class="italic muted">most valuable asset.</span></h1>
      <p class="hero__sub" data-reveal>The best conversations begin before the conversation begins. Choose the path that fits, send what you can, and the studio will respond personally.</p>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <div class="split split--end">
        <div>
          <div class="eyebrow" data-reveal>Four Paths In</div>
          <h2 class="section-title" data-reveal>Different questions.<br /><span class="italic muted">Different doors.</span></h2>
        </div>
        <p class="lede" data-reveal>Pick the closest fit. If the inquiry is thoughtful, it will get to the right place.</p>
      </div>
      <div class="feature-grid" style="margin-top:72px;">
        {contactPaths.map((path) => (
          <article class="contact-card" data-reveal>
            <div class="contact-card__number">{path.number}</div>
            <h3 class="card-title">{path.title}</h3>
            <p>{path.body}</p>
            <a class="arrow-link" href={contactProfile.mailto}>{path.label}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark" style="text-align:center;">
    <div class="container">
      <div class="eyebrow" data-reveal>Direct</div>
      <h2 class="section-title" data-reveal style="margin-inline:auto;"><a href={contactProfile.mailto}>{contactProfile.email}</a></h2>
      <p class="lede" data-reveal style="margin:28px auto 0;">WORK LABS · Richmond, Virginia</p>
    </div>
  </section>

  <section class="section section--light">
    <div class="container split">
      <div>
        <div class="eyebrow" data-reveal>Before We Speak</div>
        <h2 class="section-title" data-reveal>A few questions worth thinking about.</h2>
      </div>
      <div class="cards-grid" style="grid-template-columns:1fr;">
        {[
          'What problem are you hoping to solve?',
          'Why is it important now?',
          'What have you already tried?',
          'What do you believe is getting in the way?',
          'If this were successful, what would be different?',
        ].map((question, index) => (
          <article class="card" data-reveal>
            <div class="card__number">0{index + 1}</div>
            <h3 class="card-title">{question}</h3>
          </article>
        ))}
      </div>
    </div>
  </section>
</PageFrame>
