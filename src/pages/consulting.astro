---
import PageFrame from '../components/PageFrame.astro';
import { consultingPage, consultingTiers } from '../data/site';
---

<PageFrame title={consultingPage.title} description={consultingPage.metaDescription} currentPath="/consulting" ctaHref="/contact" ctaLabel="Request a Session">
  <section class="hero">
    <div class="container">
      <div class="eyebrow" data-reveal>Consulting</div>
      <h1 class="page-title" data-reveal>Decisions,<br /><span class="italic muted">not just deliverables.</span></h1>
      <p class="hero__sub" data-reveal>Applied Collaborative Intelligence for organizations navigating positioning, growth, launches, succession, or brand and business decisions where sequencing matters.</p>
      <div class="hero__actions" data-reveal>
        <a class="btn btn--primary" href="/contact">Begin with a WORK Session</a>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container split">
      <div>
        <div class="eyebrow" data-reveal>The Approach</div>
        <h2 class="section-title" data-reveal>This is strategic partnership built to create movement.</h2>
      </div>
      <div>
        <p class="lede" data-reveal>Some clients need a single conversation that changes the direction of a decision. Others need a longer relationship that helps leadership navigate growth, repositioning, launches, internal complexity, or the gap between what the company is and how it is showing up.</p>
        <p class="lede" data-reveal>WORK LABS is structured for both: focused enough to be useful immediately, rigorous enough to stay valuable over time.</p>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <div class="eyebrow" data-reveal>Ways to Engage</div>
      <h2 class="section-title" data-reveal>Four practical formats.</h2>
      <div class="cards-grid cards-grid--two" style="margin-top:70px;">
        {consultingTiers.map((tier) => (
          <article class="tier-card" data-reveal>
            <div class="tier-card__number">{tier.number}</div>
            <h3 class="card-title">{tier.title}</h3>
            <p class="italic brass" style="margin-top:8px;">{tier.subtitle}</p>
            <p>{tier.body}</p>
            <div class="dossier-chips">
              <span>{tier.duration}</span>
              <span>{tier.investment}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="eyebrow" data-reveal>The Instruments</div>
      <h2 class="section-title" data-reveal>Frameworks that run through every engagement.</h2>
      <div class="cards-grid" style="margin-top:70px;">
        {[
          ['Collaborative Intelligence™', 'The Operating System', 'Artificial and human intelligence used intentionally, with clear roles for speed, judgment, direction, and meaning.'],
          ['Trivergent Thinking™', 'The Decision Filter', 'Consequential moves are evaluated across time, cost, and impact at the same time.'],
          ['WORK Brand Intelligence™', 'The Diagnostic System', 'A structured way to evaluate brand health, trajectory, culture, communication, and commercial readiness.'],
        ].map(([label, title, body]) => (
          <article class="card" data-reveal>
            <p class="italic brass">{label}</p>
            <h3 class="card-title">{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <div class="eyebrow" data-reveal>Who This Is For</div>
      <h2 class="section-title" data-reveal>Organizations at real inflection points.</h2>
      <div class="cards-grid" style="margin-top:70px;">
        {[
          ['Founder-led growth companies', 'Outgrown improvisation. Need clarity, not just activity.'],
          ['Capital-backed and PE portfolio companies', 'Accountable for value creation. Mis-sequencing is expensive.'],
          ['Mid-market and legacy organizations', 'In transition, restructuring, or repositioning.'],
        ].map(([title, body]) => (
          <article class="card" data-reveal>
            <h3 class="card-title">{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark" style="text-align:center;">
    <div class="container">
      <div class="eyebrow" data-reveal>What's Next</div>
      <h2 class="section-title" data-reveal style="margin-inline:auto;">Most engagements begin with a Session.</h2>
      <p class="lede" data-reveal style="margin:28px auto 0;">Defined scope, defined investment, defined outcome. From there, the right next step usually becomes obvious.</p>
      <div class="hero__actions" data-reveal style="justify-content:center;">
        <a class="btn btn--primary" href="/contact">Request a Session</a>
      </div>
    </div>
  </section>
</PageFrame>
