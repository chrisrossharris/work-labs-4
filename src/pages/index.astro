---
import BrandPlatformGrid from '../components/BrandPlatformGrid.astro';
import PageFrame from '../components/PageFrame.astro';
import { homeFirsts, homePage, homePathways } from '../data/site';
---

<PageFrame title="WORK LABS" description={homePage.metaDescription} currentPath="/" ctaHref="/contact" ctaLabel="Start a Conversation">
  <section class="hero">
    <div class="container">
      <div class="hero__meta" data-reveal>
        <span>WORK LABS</span><span class="dot"></span><span>Richmond, VA</span><span class="dot"></span><span>Est. 1993</span>
      </div>
      <h1 class="page-title" data-reveal style="--reveal-delay:90ms;">WORK LABS.<br /><span class="italic muted">Home of Collaborative Intelligence.</span></h1>
      <p class="hero__sub" data-reveal style="--reveal-delay:160ms;">
        A brand strategy and creative studio built on a single conviction: the most powerful creative force in business today is the intelligence that emerges when artificial and human are wielded together by someone who knows the difference.
      </p>
      <div class="hero__actions" data-reveal style="--reveal-delay:230ms;">
        <a class="btn btn--primary" href="/brand-foundry">Explore the Foundry</a>
        <a class="btn" href="/ci2">Read the CI² Thesis</a>
      </div>
    </div>
  </section>

  <section class="section section--light section--compact">
    <div class="container" style="text-align:center;">
      <div class="eyebrow" data-reveal>The Operating System</div>
      <div class="formula formula--large" data-reveal style="--reveal-delay:100ms;">
        (AI<sup>2</sup>)<span class="plus">+</span>(HI<sup>2</sup>)<span class="equals">=</span>(CI<sup>2</sup>)
      </div>
      <p class="lede" data-reveal style="--reveal-delay:180ms; margin:36px auto 0;">
        <strong>Collaborative Intelligence™</strong> is the spine that runs through every brand we build, every system we design, and every decision we help clients make.
      </p>
      <svg class="triangle" data-reveal viewBox="0 0 320 220" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <line class="tri-line" style="--d:0ms;" pathLength="1" x1="54" y1="176" x2="266" y2="176" stroke="#0a0a0a" stroke-width="1.5" />
        <line class="tri-line" style="--d:160ms;" pathLength="1" x1="54" y1="176" x2="54" y2="52" stroke="#0a0a0a" stroke-width="1.5" />
        <line class="tri-line" style="--d:320ms;" pathLength="1" x1="54" y1="52" x2="266" y2="176" stroke="#c6a35a" stroke-width="3" />
        <circle cx="54" cy="176" r="5" fill="#c6a35a" />
        <circle cx="54" cy="52" r="5" fill="#c6a35a" />
        <circle cx="266" cy="176" r="5" fill="#c6a35a" />
        <text x="42" y="120" fill="#0a0a0a" font-size="18" font-family="Georgia, serif" text-anchor="end">HI</text>
        <text x="160" y="202" fill="#0a0a0a" font-size="18" font-family="Georgia, serif" text-anchor="middle">AI</text>
        <text x="182" y="106" fill="#c6a35a" font-size="18" font-family="Georgia, serif" text-anchor="middle">CI</text>
      </svg>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split split--end">
        <div>
          <div class="eyebrow" data-reveal>Three Paths In</div>
          <h2 class="section-title" data-reveal>One studio. <span class="italic muted">Three doors.</span><br />One operating system underneath.</h2>
        </div>
        <p class="lede" data-reveal>Choose the door that fits the moment. The method underneath stays the same: sharper intelligence, cleaner judgment, and work built to hold up.</p>
      </div>
      <div class="feature-grid" style="margin-top:72px;">
        {homePathways.slice(1).map((item, index) => (
          <article class="card" data-reveal>
            <div class="card__number">0{index + 1}</div>
            <h3 class="card-title">{item.title}</h3>
            <p>{item.body}</p>
            <a class="arrow-link" href={item.href}>{item.label}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--ink">
    <div class="container split">
      <div class="eyebrow" data-reveal>Why Now</div>
      <div>
        <p class="display" data-reveal style="max-width:980px; font-family:var(--serif); font-size:clamp(30px,3.4vw,48px); line-height:1.22; font-weight:300;">
          In an era when AI can generate anything, the scarcest resource is no longer content. <span class="italic brass">It is conviction.</span>
        </p>
        <p class="lede" data-reveal style="margin-top:28px;">A brand with a genuine point of view. A company that knows not just what it makes, but what it means.</p>
      </div>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">
      <div class="split split--end">
        <div>
          <div class="eyebrow" data-reveal>The Lineage</div>
          <h2 class="section-title" data-reveal>Eleven firsts.<br /><span class="italic muted">Three decades.</span><br />One studio.</h2>
        </div>
        <p class="lede" data-reveal>Being first is not a goal. It is what happens when you pay close enough attention.</p>
      </div>
      <div class="timeline">
        {homeFirsts.map((item) => (
          <div class="timeline__row" data-reveal>
            <div class="timeline__year">{item.year}</div>
            <div class="timeline__body"><strong>{item.title}</strong> {item.body}</div>
            <div class="timeline__tag">{item.tag}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split split--end">
        <div>
          <div class="eyebrow" data-reveal>The Foundry</div>
          <h2 class="section-title" data-reveal>Brands built inside <span class="italic muted">Collaborative Intelligence.</span></h2>
        </div>
        <p class="lede" data-reveal>A small, curated inventory of investment-grade brand platforms, conceived, named, designed, and framed for qualified operators and acquirers.</p>
      </div>
      <BrandPlatformGrid />
    </div>
  </section>

  <section class="section section--light">
    <div class="container split">
      <div class="founder-photo" data-reveal>
        <img src="/images/founder/cabell-harris.png" alt="Cabell Harris" />
      </div>
      <div>
        <div class="eyebrow" data-reveal>The Architect</div>
        <h2 class="section-title" data-reveal>Cabell Harris</h2>
        <p class="lede" data-reveal style="margin-top:32px;">Thirty years as a conceptual artist working in the discipline of brand. When AI arrived, the discovery was not that human judgment had become less valuable. It was that taste, instinct, context, and restraint mattered more.</p>
        <div class="quote" data-reveal>"A military strategist with a sense of humor, a mad professor with taste, and more going on in his own head than most of the advertising industry."</div>
      </div>
    </div>
  </section>

  <section class="section section--dark" style="text-align:center;">
    <div class="container">
      <div class="eyebrow" data-reveal>What's Next</div>
      <h2 class="section-title" data-reveal style="margin-inline:auto;">Outthink the competition.<br /><span class="italic muted">Do not outspend them.</span></h2>
      <div class="hero__actions" data-reveal style="justify-content:center;">
        <a class="btn btn--primary" href="/contact">Start a Conversation</a>
        <a class="btn" href="/work">View the Work</a>
      </div>
    </div>
  </section>
</PageFrame>
